{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Secret.World.Launcher",
  "version": "0.1.2",
  "identifier": "com.endlessvex.tsw-modern",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Secret World Launcher",
        "width": 760,
        "height": 550,
        "resizable": false,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "TSW Downloader"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJENzg4N0E4RkM1MkE2NDMKUldSRHBsTDhxSWQ0dld1VDZRLzU3UjZnMVBIOEs2Y2hobk1JYXVubXROVm1SaWViM053eVUzN1oK",
      "endpoints": [
        "https://github.com/EndlessVex/TSW-Modern/releases/latest/download/latest.json"
      ]
    }
  }
}
