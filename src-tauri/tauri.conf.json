{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "TSW Modern Launcher",
  "version": "0.1.0",
  "identifier": "com.endlessvex.tsw-modern",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "TSW Modern Launcher",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4QzFDN0JBQjY4MjkwMDYKUldTWXdjZTZ0b0tRQmdjUmdrV3FPWUNiUGRTdmxaMitJK3pqSU9NZnNPTGxHVTZQMDV2V3RySVAK",
      "endpoints": [
        "https://github.com/EndlessVex/TSW-Modern/releases/latest/download/latest.json"
      ]
    }
  }
}
